@model List<F1_Models.ECU>

<div class="card shadow border-0 mt-4">
    <div class="card-header bg-secondary bg-gradient py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="text-white py-2">ECU List</h2>
            </div>
        </div>
    </div>

    <div class="card-body p-4">
        <div class="row pb-3">
            <div class="col-6"></div>
            <div class="col-6 text-end">
                <a asp-area="Admin" asp-controller="ECU" asp-action="Create" class="btn btn-primary">
                    Add New ECU
                </a>
            </div>
        </div>

        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Name</th>
                    <th>Version</th>
                    <th>Limit per driver</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var obj in Model)
                {
                    <tr>
                        <td>@obj.Name</td>
                        <td>@obj.Version</td>
                        <td>@obj.Limit</td>
                        <td class="text-center">
                            <a asp-area="Admin" asp-controller="ECU" asp-action="Edit" asp-route-id="@obj.Id" class="btn btn-warning mx-1">Edit</a>
                            <a asp-area="Admin" asp-controller="ECU" asp-action="Delete" asp-route-id="@obj.Id" class="btn btn-danger mx-1">Delete</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
