@model F1_Models.Tyres

<form method="post">
    <input asp-for="Id" hidden />

    <div class="card shadow border-0 mt-4">
        <div class="card-header bg-danger bg-gradient py-3">
            <div class="row">
                <div class="col-12 text-center">
                    <h2 class="text-white py-2">Delete Tyre</h2>
                </div>
            </div>
        </div>

        <div class="card-body p-4">
            <div class="border p-3">

                <div class="mb-3">
                    <label asp-for="Name"></label>
                    <input asp-for="Name" disabled class="form-control" />
                </div>

                <div class="mb-3">
                    <label asp-for="Type"></label>
                    <input asp-for="Type" disabled class="form-control" />
                </div>

                <div class="mb-3">
                    <label asp-for="QuantityAllowed"></label>
                    <input asp-for="QuantityAllowed" disabled class="form-control" />
                </div>

                <button type="submit" class="btn btn-danger">Delete</button>
                <a asp-area="Admin" asp-controller="Tyres" asp-action="Index" class="btn btn-secondary">
                    Back to List
                </a>

            </div>
        </div>
    </div>
</form>