@model List<Manufacturer>

<div class="card shadow border-0 mt-4">
    <div class="card-header bg-secondary bg-gradient ml-0 py-3">
        <div class="row">
            <div class="col-12 text-center">
                <h2 class="text-white py-2">Manufacturer List</h2>
            </div>
        </div>
    </div>

    <div class="card-body p-4">
        <div class="row pb-3">
            <div class="col-6">
            </div>

            <div class="col-6 text-end">
                <a asp-controller="Manufacturer" asp-action="Create" class="btn btn-primary">
                    Create New Manufacturer
                </a>
            </div>
        </div>

        <table class="table table-bordered table-striped">
            <thead>
                <tr>
                    <th>Manufacturer Name</th>
                    <th>Display Order</th>
                    <th class="text-center">Actions</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var obj in Model.OrderBy(u => u.DisplayOrder))
                {
                    <tr>
                        <td>@obj.Name</td>
                        <td>@obj.DisplayOrder</td>

                        <td class="text-center">
                            <div class="btn-group" role="group">
                                <!-- EDIT BUTTON -->
                                <a asp-controller="Manufacturer"
                                   asp-action="Edit"
                                   asp-route-id="@obj.Id"
                                   class="btn btn-warning mx-1">
                                    Edit
                                </a>

                                <!-- DELETE BUTTON -->
                                <a asp-controller="Manufacturer"
                                   asp-action="Delete"
                                   asp-route-id="@obj.Id"
                                   class="btn btn-danger mx-1">
                                    Delete
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>