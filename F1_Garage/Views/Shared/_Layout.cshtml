@using Microsoft.AspNetCore.Http
@using F1_Garage.Data
@inject IHttpContextAccessor HttpContextAccessor

@{
    var role = HttpContextAccessor.HttpContext?.Session.GetString("Role");
    var userId = HttpContextAccessor.HttpContext?.Session.GetInt32("UserId");
    int cartCount = 0;

    if (role == "TeamManager" && userId != null)
    {
        var db = HttpContextAccessor.HttpContext?.RequestServices.GetService(typeof(ApplicationDbContext)) as ApplicationDbContext;

        if (db != null)
        {
            cartCount = db.CartItems.Count(c => c.UserId == userId);
        }
    }
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - F1_Garage</title>

    <link href="https://cdn.jsdelivr.net/npm/bootswatch@5.3.3/dist/sandstone/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/F1_Garage.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/css/toastr.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>

    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark border-bottom box-shadow mb-3">
            <div class="container-fluid">

                @if (role == "Admin")
                {
                    <a class="navbar-brand fw-bold" asp-area="Admin" asp-controller="Home" asp-action="Index">F1_Garage</a>
                }
                else
                {
                    <a class="navbar-brand fw-bold" asp-area="TeamManager" asp-controller="Home" asp-action="Index">F1_Garage</a>
                }

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNavbar">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="mainNavbar">
                    <ul class="navbar-nav me-auto">

                        @if (role == "Admin")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="Admin" asp-controller="Home" asp-action="Index">Home</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-area="Admin" asp-controller="Manufacturer" asp-action="Index">Manufacturer</a>
                            </li>

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown">Parts</a>
                                <ul class="dropdown-menu dropdown-menu-dark">
                                    <li><a class="dropdown-item" asp-area="Admin" asp-controller="Tyres" asp-action="Index">Tyres</a></li>
                                    <li><a class="dropdown-item" asp-area="Admin" asp-controller="ECU" asp-action="Index">ECUs</a></li>
                                </ul>
                            </li>
                        }
                        else if (role == "TeamManager")
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-area="TeamManager" asp-controller="Home" asp-action="Index">Home</a>
                            </li>

                            <li class="nav-item">
                                <a class="nav-link" asp-area="TeamManager" asp-controller="Manufacturer" asp-action="Index">Manufacturer</a>
                            </li>

                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle" data-bs-toggle="dropdown">Parts</a>
                                <ul class="dropdown-menu dropdown-menu-dark">
                                    <li><a class="dropdown-item" asp-area="TeamManager" asp-controller="Tyres" asp-action="Index">Tyres</a></li>
                                    <li><a class="dropdown-item" asp-area="TeamManager" asp-controller="ECU" asp-action="Index">ECUs</a></li>
                                </ul>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="TeamManager" asp-controller="" asp-action="Privacy">Privacy</a>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link" asp-controller="User" asp-action="Login">Login</a>
                            </li>
                        }

                    </ul>

                    <ul class="navbar-nav ms-auto">
                        @if (role != null)
                        {
                            <li class="nav-item">
                                <span class="nav-link text-info">Current User: @role</span>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link" asp-area="" asp-controller="User" asp-action="Logout">Logout</a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    @if (role == "TeamManager")
    {
        <a asp-area="TeamManager"
           asp-controller="Cart"
           asp-action="Index"
           class="cart-float-btn">
            <i class="bi bi-cart-fill"></i>

            @if (cartCount > 0)
            {
                <span class="cart-badge">@cartCount</span>
            }
        </a>
    }

    <footer class="border-top footer text-muted mt-4">
        <div class="container">
            &copy; 2026 - F1_Garage
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/toastr.js/latest/js/toastr.min.js"></script>
    <script src="~/js/site.js"></script>

    @if (TempData["Success"] != null)
    {
        <script>
            toastr.success("@TempData["Success"]");
        </script>
    }

    <script>
        toastr.options = {
            "closeButton": false,
            "progressBar": true,
            "positionClass": "toast-top-right",
            "timeOut": "2000",
            "extendedTimeOut": "1000"
        };
    </script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>